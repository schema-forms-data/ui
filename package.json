{
  "name": "@schema-forms-data/ui",
  "version": "4.0.11",
  "description": "Shared UI components (Radix UI + Tailwind) for SchemaForms packages",
  "license": "MIT",
  "author": "SchemaForms",
  "homepage": "https://schema-forms-data.github.io/schema-forms-data",
  "repository": {
    "type": "git",
    "url": "https://github.com/schema-forms-data/ui.git"
  },
  "bugs": {
    "url": "https://github.com/schema-forms-data/ui/issues"
  },
  "keywords": [
    "react",
    "ui",
    "radix-ui",
    "tailwind",
    "components",
    "schema-forms-data"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "1.3.5",
    "@radix-ui/react-dialog": "1.1.17",
    "@radix-ui/react-label": "2.1.10",
    "@radix-ui/react-popover": "1.1.17",
    "@radix-ui/react-progress": "1.1.10",
    "@radix-ui/react-radio-group": "1.4.1",
    "@radix-ui/react-scroll-area": "1.2.12",
    "@radix-ui/react-select": "2.3.1",
    "@radix-ui/react-separator": "1.1.10",
    "@radix-ui/react-slider": "1.4.1",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-switch": "1.3.1",
    "@radix-ui/react-tooltip": "1.2.10",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "tailwind-merge": "3.6.0"
  },
  "peerDependencies": {
    "lucide-react": "0.400.0",
    "react": "18.0.0",
    "react-dom": "18.0.0"
  },
  "devDependencies": {
    "@schema-forms-data/templates": "4.0.11",
    "@tailwindcss/vite": "4.3.1",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.3.1",
    "tailwindcss": "4.3.1",
    "typescript": "5.8.3",
    "vite": "6.3.5",
    "vite-plugin-dts": "4.5.4"
  },
  "packageManager": "pnpm@9.15.9"
}
